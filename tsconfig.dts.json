  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "outDir": "./tmp/dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/index-exports.ts",
    "src/database/index.ts",
    "src/puppeteer/parallel/EndpointManager.ts",
