    "src/puppeteer/parallel/launcher.runner.ts",
    "src/puppeteer/parallel/skrin.runner.ts",
    "src/puppeteer/parallel/skrin-check-data.runner.ts",
    "src/puppeteer/parallel/EndpointManager.runner.ts",
    "src/puppeteer/parallel/parallel-test.runner.ts",
