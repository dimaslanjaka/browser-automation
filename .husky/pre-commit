#!/usr/bin/sh

# Run lint-staged through Yarn so the local binary is resolved consistently
staged_files=$(git diff --cached --name-only)
if echo "$staged_files" | grep -qE '\.(php|cjs|mjs|js|ts|jsx|tsx|py|yml|yaml|json|css|scss|less|sql)$'; then
  export GIT_DISABLE_UNTRACKED_CACHE=1
  corepack yarn exec lint-staged --config lint-staged.config.js --no-stash
else
  echo "No lintable files staged — skipping lint-staged"
fi

# ---- git merge driver setup (idempotent) ----
if ! git config --get merge.resolve_hash.driver >/dev/null; then
  git config merge.resolve_hash.name "Resolve generated checksum"
  git config merge.resolve_hash.driver true
  echo "[OK] registered resolve_hash merge driver"
fi

# Verify release tarballs do not exceed 10MB
check_tarballs() {
  dir="$1"
  staged_files=$(git diff --cached --name-only)
  echo "$staged_files" | grep -q "^$dir/" || return 0
  if [ -d "$dir" ]; then
    for file in "$dir"/*.tgz; do
      [ -e "$file" ] || continue
      size_bytes=$(wc -c <"$file")
      if [ "$size_bytes" -gt $((10 * 1024 * 1024)) ]; then
        echo "Error: Tarball $file exceeds 10MB limit"
        exit 1
      fi
    done
  fi
}

check_tarballs release
check_tarballs releases