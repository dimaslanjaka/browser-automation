  },
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "binary-collections": "https://github.com/dimaslanjaka/bin/raw/09a1a1dfee36ebf0cc040fdb039f10c47bccffb5/releases/bin.tgz",
