    "@types/jest": "^30.0.0",
    "@types/minimist": "^1",
    "@types/node": "^25",
    "@types/oboe": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/watchpack": "^2",
    "@vitejs/plugin-legacy": "^8",
    "@vitejs/plugin-react": "^6",
    "autoprefixer": "^10",
    "babel-jest": "^30",
    "binary-collections": "^2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30",
    "jest-environment-jsdom": "^30",
    "lint-staged": "^17.0.5",
    "nodemon": "^3",
    "postcss": "^8",
    "postcss-nesting": "^14",
    "react": "^19",
    "react-dom": "^19",
    "rollup": "^4.60.4",
    "rollup-plugin-dts": "^6.4.1",
    "sass": "^1",
    "terser": "^5",
    "ts-jest": "^29.4.11",
    "ts-node": "^10",
    "tsup": "^8",
    "typescript": "^6",
    "vite": "^8.0.14",
    "vite-plugin-mkcert": "^2.0.0",
    "watchpack": "^2.5.1",
    "why-is-node-running": "^3"
  },
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "binary-collections": "https://github.com/dimaslanjaka/bin/raw/571e45fd542bd17e8c47dec9b5616aa4aa30e107/releases/bin.tgz",
    "cross-spawn": "https://github.com/dimaslanjaka/node-cross-spawn/raw/78b09a1f799430fb251c1b438ec56ce7957674f4/release/cross-spawn.tgz",
