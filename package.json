{
  "name": "browser-automation",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "bin/pp",
    "bin/pp.*",
    "bin/py",
    "bin/py.*",
    "bin/*.py",
    "bin/*.mjs",
    "scripts"
  ],
  "bin": {
    "ba-check": "./dist/puppeteer/parallel/check.runner.cjs",
    "ba-launch": "./dist/puppeteer/parallel/launcher.runner.cjs",
    "ba-parallel": "./bin/pp.mjs",
    "py": "./bin/py.mjs"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./dist": {
      "require": "./dist/bundle.cjs",
      "types": "./dist/index.d.ts"
    },
    "./*": {
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "types": "./dist/*.d.ts"
    },
    "./package.json": "./package.json",
    "./database": {
      "import": "./dist/database/index.mjs",
      "require": "./dist/database/index.cjs",
      "types": "./dist/database/index.d.ts"
    },
    "./puppeteer/EndpointManager": {
      "import": "./dist/puppeteer/parallel/EndpointManager.mjs",
      "require": "./dist/puppeteer/EndpointManager.cjs",
      "types": "./dist/puppeteer/EndpointManager.d.ts"
    },
    "./puppeteer/EndpointManager.connector": {
      "import": "./dist/puppeteer/parallel/EndpointManager.connector.mjs",
      "require": "./dist/puppeteer/EndpointManager.connector.cjs",
      "types": "./dist/puppeteer/EndpointManager.connector.d.ts"
    }
  },
  "scripts": {
    "build": "node build.exports.cjs && tsc -p tsconfig.rollup.json && rollup -c rollup.dist.js && rollup -c rollup.dts.js",
    "build:docs": "npm run vite:build && npm run vite:deploy",
    "build:packages": "yarn workspaces foreach --no-private --all run build",
    "build:logs": "node --no-warnings --experimental-vm-modules -r ./.vscode/js-hook.cjs scripts/build-static-html-vite-plugin.js",
    "clean": "rimraf node_modules/.vite tmp/vite tmp/.vite dist tmp/screenshot public/assets/data/screenshots tmp/puppeteer tmp/puppeteer-profile tmp/build lib",
    "clean:full": "npm run clean && rimraf node_modules && yarn install",
    "download:google-sheet": "node download-google-sheet.js",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "prepare": "husky",
    "serve-xlsx": "node xlsx-web-server.js | tee tmp/xlsx-server.log",
    "serve-xlsx-bg": "node xlsx-web-server.js > tmp/xlsx-server.log 2>&1 &",
    "test": "node --no-warnings --experimental-vm-modules -r ./.vscode/js-hook.cjs ./node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --forceExit --verbose",
    "test:coverage": "npm run test -- --coverage",
    "update:ncu": "npx -y npm-check-updates -u --reject '/eslint|rollup/'",
    "update:resolutions": "npx pkg-res-updater",
    "vite:build": "node -r ./.vscode/js-hook.cjs node_modules/vite/bin/vite.js build --mode production",
    "vite:deploy": "node -r ./.vscode/js-hook.cjs vite.deploy.js",
    "vite:dev": "node -r ./.vscode/js-hook.cjs node_modules/vite/bin/vite.js --mode development",
    "vite:preview": "node -r ./.vscode/js-hook.cjs node_modules/vite/bin/vite.js preview",
    "vite:prepare": "node -r ./.vscode/js-hook.cjs scripts/prepare-vite-plugin.js",
    "xlsx-to-html": "node xlsx-to-html.js | tee tmp/xlsx-to-html.log",
    "unused": "npx -y depcheck --ignore-dirs=packages,dist,tmp --ignores=eslint,prettier,typescript,ts-node,ts-jest,@types/\\* > tmp/depcheck-unused.txt",
    "verify": "tsc -p tsconfig.build.json --noEmit",
    "pack": "npx -y tarball-packer --yarn --filename browser-automation --normalize-resolutions"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "7zip-bin": "^5",
    "@fancyapps/ui": "^6.1.14",
