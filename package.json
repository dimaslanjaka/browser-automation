    "@rollup/plugin-typescript": "^12.3.0",
    "@testing-library/dom": "^10",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/babel__core": "^7",
    "@types/babel__preset-env": "^7",
