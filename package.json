    "node-fetch": "^3",
    "node-xlsx": "^0",
    "nunjucks": "^3",
    "oboe": "^2.1.7",
    "play-sound": "^1",
    "playwright": "^1",
    "playwright-extra": "^4",
    "proxies-grabber": "^1",
    "puppeteer": "25",
    "puppeteer-cluster": "^0.25.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-adblocker": "^2.13.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "puppeteer-real-browser": "^1.4.4",
    "puppeteer-with-fingerprints": "^2.3.5",
    "react-bootstrap": "^2",
    "react-ga4": "^3.0.1",
    "react-router-dom": "^7",
    "safelinkify": "^1",
    "sbg-utility": "^2.0.11",
    "socket.io": "^4",
    "socks-proxy-agent": "^10",
    "tree-kill": "^1.2.2",
    "unicode-symbols": "^7.6.0",
    "unzipper": "^0",
    "upath": "^3.0.7",
    "xlsx": "^0",
    "xlsx-extract": "^0",
    "xlsx-style": "^0"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/plugin-syntax-import-assertions": "^7",
    "@babel/preset-env": "^7",
